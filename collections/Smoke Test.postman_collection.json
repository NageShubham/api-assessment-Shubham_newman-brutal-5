    {
      "name": "POST_DummyJSON Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status should be 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Token starts with eyJ\", function () {\r",
              "    pm.expect(jsonData.accessToken.startsWith(\"eyJ\")).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.environment.set(\r",
              "    \"djToken\",\r",
              "    jsonData.accessToken\r",
              ");\r",
              "\r",
              "pm.environment.set(\r",
              "    \"djRefreshToken\",\r",
              "    jsonData.refreshToken\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"emilys\",\r\n  \"password\": \"emilyspass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
