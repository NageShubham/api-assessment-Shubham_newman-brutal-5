    {
      "name": "Request_10_Cross-System_User_Validation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const djUserId =\r",
              "parseInt(\r",
              "    pm.environment.get(\"djUserId\")\r",
              ");\r",
              "\r",
              "if (djUserId <= 10) {\r",
              "\r",
              "    pm.test(\"Should return 200\", () => {\r",
              "        pm.response.to.have.status(200);\r",
              "    });\r",
              "\r",
              "    const jsonData =\r",
              "    pm.response.json();\r",
              "\r",
              "    pm.test(\r",
              "        \"Emails should differ\",\r",
              "        () => {\r",
              "\r",
              "            pm.expect(\r",
              "                jsonData.email\r",
              "            ).to.not.eql(\r",
              "                pm.environment.get(\"djEmail\")\r",
              "            );\r",
              "        }\r",
              "    );\r",
              "\r",
              "} else {\r",
              "\r",
              "    pm.test(\"Should return 404\", () => {\r",
              "        pm.response.to.have.status(404);\r",
              "    });\r",
              "\r",
              "    console.log(\r",
              "        \"Cross-system ID range finding documented\"\r",
              "    );\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [],
            "type": "text/javascript"
