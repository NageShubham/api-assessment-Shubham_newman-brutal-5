    {
      "name": "Request_7_FakeStore_Products_Analysis",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const products =\r",
              "pm.response.json();\r",
              "\r",
              "pm.environment.set(\r",
              "    \"fsProductCount\",\r",
              "    products.length\r",
              ");\r",
              "\r",
              "let topRated =\r",
              "products[0];\r",
              "\r",
              "products.forEach(product => {\r",
              "\r",
              "    if (\r",
              "        product.rating.rate >\r",
              "        topRated.rating.rate\r",
              "    ) {\r",
              "        topRated = product;\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.environment.set(\r",
              "    \"topRatedTitle\",\r",
              "    topRated.title\r",
              ");"
            ],
