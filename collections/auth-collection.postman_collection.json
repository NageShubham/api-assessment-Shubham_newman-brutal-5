  "item": [
    {
      "name": "POST_Request 1- Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response JSON\r",
              "const json = pm.response.json();\r",
              "\r",
              "// Capture tokens\r",
              "pm.environment.set(\"capturedToken\", json.accessToken);\r",
              "pm.environment.set(\"refreshToken\", json.refreshToken);\r",
              "\r",
              "// Decode JWT payload (middle segment)\r",
              "const payload =\r",
              "JSON.parse(atob(json.accessToken.split('.')[1]));\r",
              "\r",
              "// Capture JWT values\r",
              "pm.environment.set(\"djUserId\", payload.id);\r",
              "pm.environment.set(\"djUsername\", payload.username);\r",
              "\r",
              "// Current Unix timestamp (seconds)\r",
              "const currentUnixTime = Math.floor(Date.now() / 1000);\r",
              "\r",
              "// Assertions\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"accessToken starts with eyJ and is valid string > 50 chars\", function () {\r",
              "    pm.expect(json.accessToken).to.be.a(\"string\");\r",
              "    pm.expect(json.accessToken.startsWith(\"eyJ\")).to.be.true;\r",
              "    pm.expect(json.accessToken.length).to.be.greaterThan(50);\r",
              "});\r",
              "\r",
              "pm.test(\"refreshToken is different from accessToken and > 50 chars\", function () {\r",
              "    pm.expect(json.refreshToken).to.be.a(\"string\");\r",
              "    pm.expect(json.refreshToken).to.not.equal(json.accessToken);\r",
              "    pm.expect(json.refreshToken.length).to.be.greaterThan(50);\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "pm.test(\"exp is a future Unix timestamp\", function () {\r",
              "    pm.expect(payload.exp).to.be.a(\"number\");\r",
              "    pm.expect(payload.exp).to.be.greaterThan(currentUnixTime);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"{{csv_username}}\",\r\n  \"password\": \"{{csv_password}}\"\r\n}",
          "options": {
