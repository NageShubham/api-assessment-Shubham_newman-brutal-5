              "}\r",
              "\r",
              "pm.test(`[${scenario}] Status is 200`, function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const responseBody = pm.response.json();\r",
              "\r",
              "pm.test(`[${scenario}] New accessToken is a string`, function () {\r",
