              "});\r",
              "\r",
              "const responseBody = pm.response.json();\r",
              "\r",
              "// HTTPBin title-cases header names — so 'Authorization' not 'authorization'\r",
              "const echoedAuth = responseBody.headers['Authorization'];\r",
              "\r",
              "// Assert Authorization header is echoed back\r",
              "pm.test('Authorization header is echoed back', function () {\r",
              "    pm.expect(echoedAuth).to.be.a('string');\r",
              "    pm.expect(echoedAuth.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "// Assert echoed value starts with 'Bearer '\r",
              "pm.test('Echoed Authorization starts with Bearer', function () {\r",
              "    pm.expect(echoedAuth).to.match(/^Bearer /);\r",
              "});"
            ],
