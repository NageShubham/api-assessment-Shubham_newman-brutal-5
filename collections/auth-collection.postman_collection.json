  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Only re-login if current iteration expects a valid login (expectedStatus === 200)\r",
          "const expectedStatus = parseInt(pm.iterationData.get('expectedStatus'));\r",
          "const scenario = pm.iterationData.get('scenario');\r",
          "\r",
          "console.log(`\\n--- Iteration: ${scenario} | Expected: ${expectedStatus} ---`);\r",
          "\r",
          "if (expectedStatus === 200) {\r",
          "    // For valid scenarios — login with CSV credentials to get fresh token\r",
          "    const baseUrl = 'https://dummyjson.com';\r",
          "    const username = pm.iterationData.get('csv_username');\r",
          "    const password = pm.iterationData.get('csv_password');\r",
          "\r",
          "    const loginRequest = {\r",
          "        url: baseUrl + '/auth/login',\r",
          "        method: 'POST',\r",
          "        header: [\r",
          "            { key: 'Content-Type', value: 'application/json' }\r",
          "        ],\r",
          "        body: {\r",
          "            mode: 'raw',\r",
          "            raw: JSON.stringify({\r",
          "                username: username,\r",
          "                password: password,\r",
          "                expiresInMins: 60\r",
          "            })\r",
          "        }\r",
          "    };\r",
          "\r",
          "    pm.sendRequest(loginRequest, function (err, res) {\r",
          "        if (err) {\r",
          "            console.error('Pre-login failed:', err);\r",
          "            return;\r",
          "        }\r",
          "\r",
          "        const json = res.json();\r",
          "\r",
          "        if (json.accessToken) {\r",
          "            pm.collectionVariables.set('capturedToken', json.accessToken);\r",
          "            pm.collectionVariables.set('capturedRefreshToken', json.refreshToken);\r",
          "            console.log(`✅ [${scenario}] Fresh token captured for valid login`);\r",
          "        } else {\r",
          "            console.error(`❌ [${scenario}] Login failed unexpectedly:`, JSON.stringify(json));\r",
          "        }\r",
          "    });\r",
          "\r",
          "} else {\r",
          "    // For failure scenarios — clear token so negative tests work cleanly\r",
          "    console.log(`⚠️ [${scenario}] Failure scenario — skipping pre-login`);\r",
          "}"
        ]
      }
    },
